{
  "name": "registar-zadachi",
  "private": true,
  "version": "1.0.0",
  "description": "Българска система за следене на задачи с рег. номер, дата и автоматично изчисляване на срокове.",
  "author": "",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "tsc -b && vite build",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder --win --publish never",
    "dist:dir": "npm run build && electron-builder --win --dir"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "concurrently": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "bg.registar.zadachi",
    "productName": "Следене на задачи",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*", "package.json"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "Registar-Zadachi-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Следене на задачи"
    }
  }
}
